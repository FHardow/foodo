# Public domain (no protocol, no trailing slash)
DOMAIN=fhardow.de

# TLS — email for Let's Encrypt notifications (only needed in docker-compose.traefik.yml)
ACME_EMAIL=you@example.com

# PostgreSQL
DB_USER=bread
DB_PASSWORD=changeme
DB_NAME=bread_order

# Keycloak — external instance, not managed by this compose file
KEYCLOAK_URL=https://auth.fhardow.de
KEYCLOAK_REALM=bread-order
KEYCLOAK_CLIENT_ID=bread-frontend

# Baked into the frontend at build time
VITE_KEYCLOAK_URL=https://auth.fhardow.de
