# Public domain (no protocol, no trailing slash)
DOMAIN=example.com

# TLS — email for Let's Encrypt notifications (only needed in docker-compose.traefik.yml)
ACME_EMAIL=you@example.com

# PostgreSQL
DB_USER=foodo
DB_PASSWORD=changeme
DB_NAME=foodo

# CORS — set to the frontend origin for local dev; leave empty in prod (same-origin via Traefik)
CORS_ORIGIN=

# Keycloak — external instance, not managed by this compose file
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=foodo
KEYCLOAK_CLIENT_ID=foodo-app

# Baked into the frontend at build time
VITE_KEYCLOAK_URL=https://auth.example.com
VITE_KEYCLOAK_CLIENT_ID=foodo-app
