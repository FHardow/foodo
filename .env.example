# Public domain (no protocol, no trailing slash)
DOMAIN=bread.example.com

# TLS — email for Let's Encrypt notifications
ACME_EMAIL=you@example.com

# PostgreSQL
DB_USER=bread
DB_PASSWORD=changeme
DB_NAME=bread_order

# Keycloak
KEYCLOAK_REALM=bread-order
KEYCLOAK_CLIENT_ID=bread-frontend
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
